{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "localroots.love"
        }
      ],
      "destination": "https://www.localroots.love/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/admin/rp-index",
      "schedule": "*/5 * * * *"
    }
  ]
}
